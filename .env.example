# ============================================
# Crypto Platform Environment Variables
# ============================================

# --- General (BaseSchema) ---
NODE_ENV=development                # development, production, test
LOG_LEVEL=info                      # trace, debug, info, warn, error, fatal

# --- Valkey / Redis (ValkeySchema + RedisAuthSchema) ---
VALKEY_HOST=localhost               # Valkey/Redis host
VALKEY_PORT=6379                    # Valkey/Redis port
VALKEY_PASSWORD=                    # Optional password for Valkey (leave empty if none)

# --- PostgreSQL (PGSchema) ---
PG_HOST=localhost                   # PostgreSQL host
PG_PORT=5432                        # PostgreSQL port
PG_USER=crypto                      # PostgreSQL username
PG_PASSWORD=CHANGE_ME               # PostgreSQL password (change me!)
PG_DB=crypto                        # PostgreSQL database name

# --- ClickHouse (CHSchema) ---
CLICKHOUSE_HOST=localhost           # ClickHouse host
CLICKHOUSE_PORT=8123                # ClickHouse HTTP port
CLICKHOUSE_DB=crypto                # ClickHouse database name

# --- WebSocket Gateway (ws-gateway) ---
WS_PORT=4000                        # Port for WebSocket server

# --- Orchestrator ---
ORCHESTRATOR_PORT=3010              # Port for orchestrator HTTP API

# --- Authentication (JwtSchema) ---
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS_LONG_STRING  # Secret for JWT signing (min 32 chars)

# --- Exchanges (ExchangeSchema) ---
EXCHANGE_LIST=binance,bybit,okx     # Comma-separated list of exchange IDs supported
EXCHANGE_CCXT_VERSION=4.4.82        # Optional: pin specific CCXT version (leave empty for latest)

# --- Other potential variables (from trades-core, etc.) ---
# Add any other environment variables used in other cores below.
# Example:
# SUBSCRIPTION_BATCH_SIZE=100
# METRICS_PORT=9090