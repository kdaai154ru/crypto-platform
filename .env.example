# ─────────────────────────────────────────────────────────────────────────────
# crypto-platform — .env.example
# Copy this file to .env and fill in the values before running the project.
# NEVER commit the actual .env file (it is in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ── Valkey / Redis ────────────────────────────────────────────────────────────
VALKEY_HOST=127.0.0.1
VALKEY_PORT=6379
# Required in production — generate with: openssl rand -hex 32
VALKEY_PASSWORD=

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=crypto
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── PostgreSQL (Grafana backend) ──────────────────────────────────────────────
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=grafana
POSTGRES_USER=grafana
POSTGRES_PASSWORD=

# ── JWT (ws-gateway) ──────────────────────────────────────────────────────────
# Required in production — generate with: openssl rand -hex 32
# Minimum 32 characters. Used for HMAC-SHA256 signing of WebSocket tokens.
JWT_SECRET=
JWT_ISSUER=crypto-platform

# ── WebSocket Gateway ─────────────────────────────────────────────────────────
WS_PORT=4000
# Comma-separated list of allowed origins for WebSocket upgrade (CSWSH prevention).
# Example: https://yourdomain.com,https://app.yourdomain.com
# Leave empty to disable origin validation (unsafe in production).
WS_ALLOWED_ORIGINS=

# ── Orchestrator ─────────────────────────────────────────────────────────────
ORCHESTRATOR_PORT=3010

# ── Frontend (Nuxt 3) ─────────────────────────────────────────────────────────
NUXT_PUBLIC_WS_URL=ws://localhost:4000
NUXT_PUBLIC_API_URL=http://localhost:3010
FRONTEND_PORT=3001

# ── Metrics (Prometheus) ─────────────────────────────────────────────────────
METRICS_PORT=3001
WS_METRICS_PORT=4001

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=

# ── Exchanges (exchange-core) ─────────────────────────────────────────────────
# Comma-separated list of exchange IDs to connect to.
# Supported: binance, bybit, okx, ...
EXCHANGES=binance,bybit
# Comma-separated list of trading pairs to subscribe to.
PAIRS=BTC/USDT,ETH/USDT
# Comma-separated list of timeframes.
TIMEFRAMES=1m,5m,15m,1h,4h,1d
