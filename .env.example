# ============================================
# Crypto Platform — Environment Variables
# Скопируй в .env и заполни значения
# ============================================

# ─── General (BaseSchema) ───────────────────
NODE_ENV=development                # development | production | test
LOG_LEVEL=info                      # trace | debug | info | warn | error | fatal

# ─── Valkey / Redis (ValkeySchema) ──────────
VALKEY_HOST=localhost
VALKEY_PORT=6379
# ОБЯЗАТЕЛЬНО задай сильный пароль в production!
# Пустое значение = Valkey запустится БЕЗ аутентификации (requirepass отключается)
VALKEY_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── PostgreSQL (PGSchema) ───────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=crypto
PG_PASSWORD=CHANGE_ME
PG_DB=crypto
# Алиасы для docker-compose (совместимость)
POSTGRES_USER=crypto
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=crypto

# ─── ClickHouse (CHSchema) ────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123               # HTTP port
CLICKHOUSE_DB=crypto
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=CHANGE_ME

# ─── WebSocket Gateway ──────────────────
WS_PORT=4000                        # WebSocket сервер
METRICS_PORT=9090                   # Prometheus /metrics эндпоинт

# Origin validation — защита от CSWSH (Cross-Site WebSocket Hijacking)
# Список разрешённых Origins через запятую. Пусто = проверка отключена (только dev!)
# Пример: WS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
WS_ALLOWED_ORIGINS=

# ─── Orchestrator ──────────────────────
ORCHESTRATOR_PORT=3010

# ─── Frontend (Nuxt) ────────────────────
FRONTEND_PORT=3001
NUXT_PUBLIC_WS_URL=ws://localhost:4000
NUXT_PUBLIC_API_URL=http://localhost:3010

# ─── Auth (JwtSchema) ───────────────────
# FIX(audit): placeholder специально короче min(32) — zod откажет при старте
# если не задать реальный секрет. Генерация: openssl rand -hex 32
JWT_SECRET=REPLACE_THIS

# FIX #8 (audit): JWT Issuer — проверяется поле iss в JWT-токене
# Токены из другой среды / сервиса с иным iss будут отклонены
# Должно совпадать с полем iss при генерации токена
JWT_ISSUER=crypto-platform

# ─── Exchanges (ExchangeSchema) ─────────────
EXCHANGE_LIST=binance,bybit,okx     # Comma-separated список бирж
EXCHANGE_CCXT_VERSION=              # Пусто = latest, или например 4.4.82

# ─── Grafana ────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ─── Metrics ports (по сервису) ───────────
# Каждый core поднимает свой /metrics на отдельном порту:
# exchange-core    → METRICS_PORT=4001
# normalizer-core  → METRICS_PORT=4002
# aggregator-core  → METRICS_PORT=4003
# screener-core    → METRICS_PORT=4004
# trades-core      → METRICS_PORT=4005
# indicator-core   → METRICS_PORT=4006
# alert-core       → METRICS_PORT=4007
# ws-gateway       → METRICS_PORT=4008
# worker-core      → METRICS_PORT=4009
# storage-core     → METRICS_PORT=4010
# whale-core       → METRICS_PORT=4011
# derivatives-core → METRICS_PORT=4012
# etf-core         → METRICS_PORT=4013
# options-core     → METRICS_PORT=4014
# subscription-core→ METRICS_PORT=4015
